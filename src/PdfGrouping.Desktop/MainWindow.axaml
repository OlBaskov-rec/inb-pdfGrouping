<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PdfGrouping.Desktop.ViewModels"
        xmlns:l="clr-namespace:PdfGrouping.Desktop.Localization"
        xmlns:conv="clr-namespace:PdfGrouping.Desktop.Converters"
        xmlns:models="clr-namespace:PdfGrouping.Core.Models;assembly=PdfGrouping.Core"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="PdfGrouping.Desktop.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainViewModel"
        Title="PDF Grouping — Разделение и группировка PDF"
        Icon="/Assets/app.ico"
        Width="1000" Height="720" MinWidth="780" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        DragDrop.AllowDrop="True">

    <Window.Resources>
        <conv:BoolToBrushConverter x:Key="BoolToBrush" />
        <conv:AngleToTransformConverter x:Key="AngleToTransform" />
    </Window.Resources>

    <Grid Margin="12">
      <Grid ColumnDefinitions="Auto,*">

        <!-- Панель предпросмотра (слева, включается кнопкой «👁 Предпросмотр») -->
        <Border Grid.Column="0" Width="300" Margin="0,0,12,0"
                BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10"
                IsVisible="{Binding IsPreviewEnabled}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="{l:Tr Preview_Title}"
                           FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock DockPanel.Dock="Top"
                           Text="{l:Tr Preview_Hint}"
                           TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"
                           Foreground="#777" FontSize="12" IsVisible="{Binding !HasPreview}" />
                <ScrollViewer IsVisible="{Binding HasPreview}">
                    <StackPanel>
                        <!-- Начальная страница -->
                        <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,3">
                            <Run Text="{l:Tr Preview_StartPageLabel}" />
                            <Run Text=": " />
                            <Run Text="{Binding SelectedRange.StartPage}" />
                        </TextBlock>
                        <Border Background="#F7F7F7" BorderBrush="#E0E0E0" BorderThickness="1" Padding="4"
                                HorizontalAlignment="Center" Cursor="Hand"
                                PointerPressed="StartThumb_PointerPressed"
                                ToolTip.Tip="{l:Tr Tip_ZoomStart}">
                            <Image Source="{Binding StartThumb}" Stretch="Uniform" MaxHeight="230" />
                        </Border>
                        <Button Content="{l:Tr Btn_Zoom}" Margin="0,4,0,0" HorizontalAlignment="Center"
                                Command="{Binding ZoomStartCommand}"
                                ToolTip.Tip="{l:Tr Tip_ZoomStart}" />

                        <!-- Разделитель с информацией о диапазоне -->
                        <Grid ColumnDefinitions="*,Auto,*" Margin="0,12">
                            <Border Grid.Column="0" Height="1" Background="#D8D8D8" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Margin="8,0" FontSize="12" Foreground="#666"
                                       VerticalAlignment="Center" Text="{Binding PreviewRangeText}" />
                            <Border Grid.Column="2" Height="1" Background="#D8D8D8" VerticalAlignment="Center" />
                        </Grid>

                        <!-- Конечная страница -->
                        <TextBlock FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,3">
                            <Run Text="{l:Tr Preview_EndPageLabel}" />
                            <Run Text=": " />
                            <Run Text="{Binding SelectedRange.EndPage}" />
                        </TextBlock>
                        <Border Background="#F7F7F7" BorderBrush="#E0E0E0" BorderThickness="1" Padding="4"
                                HorizontalAlignment="Center" Cursor="Hand"
                                PointerPressed="EndThumb_PointerPressed"
                                ToolTip.Tip="{l:Tr Tip_ZoomEnd}">
                            <Image Source="{Binding EndThumb}" Stretch="Uniform" MaxHeight="230" />
                        </Border>
                        <Button Content="{l:Tr Btn_Zoom}" Margin="0,4,0,0" HorizontalAlignment="Center"
                                Command="{Binding ZoomEndCommand}"
                                ToolTip.Tip="{l:Tr Tip_ZoomEnd}" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Auto,*,Auto,Auto: верх / прокручиваемая середина / закреплённая зона сообщений / низ -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto,Auto">

        <!-- Верхняя панель: справа выбор языка + значок «О программе» -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <!-- Выбор языка: квадратная кнопка с кодом текущего языка -->
                <Button Content="{Binding LanguageShort}" Width="40" Padding="6,4" Margin="0,0,6,0"
                        FontWeight="Bold" HorizontalContentAlignment="Center"
                        ToolTip.Tip="{l:Tr Tip_Language}">
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="Русский"   Command="{Binding SetLanguageCommand}" CommandParameter="ru" />
                            <MenuItem Header="English"   Command="{Binding SetLanguageCommand}" CommandParameter="en" />
                            <MenuItem Header="Français"  Command="{Binding SetLanguageCommand}" CommandParameter="fr" />
                            <MenuItem Header="Español"   Command="{Binding SetLanguageCommand}" CommandParameter="es" />
                            <MenuItem Header="Deutsch"   Command="{Binding SetLanguageCommand}" CommandParameter="de" />
                            <MenuItem Header="Italiano"  Command="{Binding SetLanguageCommand}" CommandParameter="it" />
                            <MenuItem Header="中文"       Command="{Binding SetLanguageCommand}" CommandParameter="zh" />
                            <MenuItem Header="日本語"     Command="{Binding SetLanguageCommand}" CommandParameter="ja" />
                            <MenuItem Header="한국어"     Command="{Binding SetLanguageCommand}" CommandParameter="ko" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <!-- «О программе»: только значок. Зелёный фон + мигание, когда доступно обновление. -->
                <Button Content="ℹ" Padding="9,4" FontSize="15" HorizontalContentAlignment="Center"
                        Classes.updateAvailable="{Binding IsUpdateAvailable}"
                        ToolTip.Tip="{l:Tr Tip_About}">
                    <Button.Styles>
                        <Style Selector="Button.updateAvailable /template/ ContentPresenter">
                            <Setter Property="Background" Value="#3A8A3F" />
                        </Style>
                        <Style Selector="Button.updateAvailable:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="#2E6F33" />
                        </Style>
                        <Style Selector="Button.updateAvailable">
                            <Style.Animations>
                                <Animation Duration="0:0:0.8" IterationCount="5">
                                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.4" /></KeyFrame>
                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </Button.Styles>
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <StackPanel Width="300">
                                <TextBlock Text="PDF Grouping" FontWeight="Bold" FontSize="16" />
                                <TextBlock Text="slice &amp; group PDF" FontStyle="Italic" Foreground="#555" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding AppVersionText}"
                                           Foreground="#555" Margin="0,0,0,4" />
                                <TextBlock Text="{l:Tr About_Author}" Margin="0,0,0,2" />
                                <TextBlock Text="github.com/OlBaskov-rec/inb-pdfGrouping"
                                           Foreground="#777" FontSize="12" />
                                <Border Height="1" Background="#E0E0E0" Margin="0,8" />
                                <!-- Обычная ручная проверка (когда обновление ещё не найдено) -->
                                <Button Content="{l:Tr About_CheckUpdate}"
                                        IsVisible="{Binding ShowCheckButton}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Command="{Binding CheckUpdatesManualCommand}" />
                                <!-- Зелёная кнопка: обновление найдено автоматически -->
                                <Button Content="{Binding UpdateFoundButtonText}"
                                        IsVisible="{Binding ShowRevealButton}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Background="#3A8A3F" Foreground="White" FontWeight="Bold"
                                        Command="{Binding RevealUpdateCommand}" />
                                <TextBlock Text="{Binding UpdateCheckStatus}" TextWrapping="Wrap"
                                           FontSize="12" Foreground="#555" Margin="0,6,0,0" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
            <TextBlock />
        </DockPanel>

        <ScrollViewer Grid.Row="1" x:Name="ContentScroll"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
        <!-- Правый отступ — зазор под вертикальную полосу прокрутки, чтобы она не наезжала -->
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,0,24,0">

        <!-- Row 0: исходный файл -->
        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                Padding="10" Margin="0,0,0,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="{l:Tr Source_Title}"
                           FontWeight="Bold" Margin="0,0,0,6" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button Content="{l:Tr Btn_Browse}" Command="{Binding BrowseSourceFileCommand}"
                            ToolTip.Tip="{l:Tr Tip_BrowseSource}" />
                    <Button Content="✕" Margin="6,0,0,0" Foreground="#C42B1C"
                            Command="{Binding ClearAllCommand}" ToolTip.Tip="{l:Tr Tip_ClearAll}" />
                </StackPanel>
                <TextBox Text="{Binding SourceFilePath}" IsReadOnly="True"
                         PlaceholderText="{l:Tr Source_Placeholder}"
                         VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Row 1: всего страниц (под блоком пути к файлу) -->
        <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="4" Padding="8" Margin="0,0,0,8">
            <TextBlock>
                <Run Text="{l:Tr Total_Pages}" Foreground="Gray" />
                <Run Text="{Binding TotalPages}" FontWeight="Bold" />
            </TextBlock>
        </Border>

        <!-- Row 2: диапазоны | метка | группы (высота по списку диапазонов; колонки тянутся вместе) -->
        <!-- MinWidth колонок не даёт секции «Диапазоны» сжаться под два поля номеров (наезжание при предпросмотре). -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="350" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="250" />
            </Grid.ColumnDefinitions>

            <!-- Диапазоны -->
            <Border Grid.Column="0" MinWidth="240" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Text="{l:Tr Ranges_Title}" FontWeight="Bold" Margin="0,0,0,6" />

                    <StackPanel Grid.Row="1" Margin="0,0,0,0">
                        <TextBlock Text="{Binding PagesOfText}" Margin="0,0,0,4" Foreground="#444" />
                        <!-- Поля заблокированы, пока висит вопрос (пересечение или конфликт). -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                    IsEnabled="{Binding IsRangeInputEnabled}">
                            <NumericUpDown Value="{Binding RangeStart}" Minimum="1" Maximum="{Binding MaxPage}"
                                           Increment="1" FormatString="0" Width="140" FontSize="16"
                                           ToolTip.Tip="{l:Tr Tip_RangeStart}" />
                            <TextBlock Text="–" VerticalAlignment="Center" Margin="8,0" FontSize="16" />
                            <NumericUpDown Value="{Binding RangeEnd}" Minimum="1" Maximum="{Binding MaxPage}"
                                           Increment="1" FormatString="0" Width="140" FontSize="16"
                                           ToolTip.Tip="{l:Tr Tip_RangeEnd}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,6">
                        <Button Margin="0,12,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding AddRangeCommand}" IsEnabled="{Binding !IsProcessing}">
                            <TextBlock Text="{l:Tr Btn_AddRange}" TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                        <Button Margin="0,12,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding AddRangePaginatedCommand}" IsEnabled="{Binding !IsProcessing}"
                                ToolTip.Tip="{l:Tr Tip_AddRangePaginated}">
                            <TextBlock Text="{l:Tr Btn_AddRangePaginated}" TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                        <DockPanel LastChildFill="False" Margin="0,18,0,0">
                            <Button DockPanel.Dock="Left" Content="{l:Tr Btn_Clear}"
                                    Command="{Binding ClearRangesCommand}" />
                            <ToggleButton DockPanel.Dock="Right" Content="{l:Tr Btn_Preview}"
                                          IsChecked="{Binding IsPreviewEnabled}"
                                          ToolTip.Tip="{l:Tr Tip_Preview}" />
                        </DockPanel>
                    </StackPanel>

                    <ListBox Grid.Row="3" ItemsSource="{Binding Ranges}"
                             Height="{Binding RangesListHeight}"
                             Padding="2,2,18,2"
                             SelectionMode="Single"
                             SelectedItem="{Binding SelectedRange}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:PageRange">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{l:Tr Range_PagesShort}" FontSize="11" Foreground="Gray" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding StartPage}" FontWeight="Bold" Margin="3,0,0,0" />
                                        <TextBlock Text="–" Margin="3,0" />
                                        <TextBlock Text="{Binding EndPage}" FontWeight="Bold" />
                                        <TextBlock Text=" (" FontSize="11" Foreground="Gray" />
                                        <TextBlock Text="{Binding PageCount}" FontSize="11" Foreground="Gray" />
                                        <TextBlock Text=" " FontSize="11" Foreground="Gray" />
                                        <TextBlock Text="{l:Tr Unit_PagesShort}" FontSize="11" Foreground="Gray" />
                                        <TextBlock Text=")" FontSize="11" Foreground="Gray" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="✕" Padding="6,2" Foreground="#C42B1C"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{ReflectionBinding $parent[ListBox].DataContext.RemoveRangeCommand}"
                                            CommandParameter="{Binding}" ToolTip.Tip="{l:Tr Tip_RemoveRange}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Метка группы -->
            <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                    Padding="10" Margin="8,0" Width="210">
                <!-- Auto,Auto,Auto (без *-строки: внутри внешней прокрутки * мерится некорректно). -->
                <Grid RowDefinitions="Auto,Auto,Auto">
                    <!-- Верх: метка, поле ввода, быстрый выбор, заголовок списка -->
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{l:Tr Label_Title}" FontWeight="Bold" Margin="0,0,0,2" />
                        <TextBlock Text="{l:Tr Label_Hint}" FontSize="12" Foreground="#777" Margin="0,0,0,2" />
                        <TextBox Text="{Binding GroupLabelText}" MaxLength="15"
                                 PlaceholderText="{l:Tr Label_Placeholder}" />
                        <!-- Быстрый выбор метки: 5 кнопок в один ряд -->
                        <WrapPanel Margin="0,6,0,0">
                            <Button Content="A" Width="30" Margin="0,0,4,0" Command="{Binding PickLabelCommand}" CommandParameter="A" />
                            <Button Content="B" Width="30" Margin="0,0,4,0" Command="{Binding PickLabelCommand}" CommandParameter="B" />
                            <Button Content="C" Width="30" Margin="0,0,4,0" Command="{Binding PickLabelCommand}" CommandParameter="C" />
                            <Button Content="D" Width="30" Margin="0,0,4,0" Command="{Binding PickLabelCommand}" CommandParameter="D" />
                            <Button Content="E" Width="30" Command="{Binding PickLabelCommand}" CommandParameter="E" />
                        </WrapPanel>
                        <TextBlock Text="{l:Tr Label_CurrentRanges}" FontWeight="SemiBold" FontSize="12" Margin="0,12,0,2" />
                    </StackPanel>

                    <!-- Середина: список выбранных диапазонов. MaxHeight ограничивает высоту (~5 строк),
                         дальше прокрутка — секция не «улетает» вниз при большом числе диапазонов. -->
                    <ScrollViewer Grid.Row="1" MaxHeight="130"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto" Margin="0,0,0,4">
                        <TextBlock Text="{Binding RangesDisplayText}" TextWrapping="Wrap" Foreground="#555" />
                    </ScrollViewer>

                    <!-- Низ: кнопки создания группы -->
                    <StackPanel Grid.Row="2">
                        <Button Margin="0,12,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding AddGroupCommand}" IsEnabled="{Binding !IsProcessing}">
                            <TextBlock Text="{l:Tr Btn_CreateGroup}"
                                       TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                        <Button Margin="0,12,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding AddGroupPerRangeCommand}" IsEnabled="{Binding !IsProcessing}"
                                ToolTip.Tip="{l:Tr Tip_CreateGroupPerRange}">
                            <TextBlock Text="{l:Tr Btn_CreateGroupPerRange}"
                                       TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Группы -->
            <Border Grid.Column="2" MinWidth="240" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10">
                <Grid RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Row="0" Text="{l:Tr Groups_Title}" FontWeight="Bold" Margin="0,0,0,6" />

                    <!-- MaxHeight: ~5 групп, дальше прокрутка — секция не «улетает» вниз. -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding Groups}" MaxHeight="260"
                             VerticalAlignment="Top">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:PdfGroup">
                                <Grid ColumnDefinitions="*,Auto">
                                    <WrapPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Label, StringFormat='[{0}]'}"
                                                   FontWeight="Bold" Foreground="#0078D4" />
                                        <TextBlock Text=" — " FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding TotalPages}" FontWeight="SemiBold" />
                                        <TextBlock Text=" " FontWeight="SemiBold" />
                                        <TextBlock Text="{l:Tr Unit_PagesShort}" FontWeight="SemiBold" />
                                        <TextBlock Text="  " FontSize="11" Foreground="#777" />
                                        <TextBlock Text="{l:Tr Group_RangesPrefix}" FontSize="11" Foreground="#777" />
                                        <TextBlock Text="{Binding RangesText}" FontSize="11" Foreground="#777" />
                                        <TextBlock Text=")" FontSize="11" Foreground="#777" />
                                    </WrapPanel>
                                    <Button Grid.Column="1" Content="✕" Padding="6,2" Foreground="#C42B1C"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{ReflectionBinding $parent[ListBox].DataContext.RemoveGroupCommand}"
                                            CommandParameter="{Binding}" ToolTip.Tip="{l:Tr Tip_RemoveGroup}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Результаты (созданные файлы) — остаются в прокручиваемой середине -->
        <Border Grid.Row="6" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                Padding="10" Margin="0,8,0,0" IsVisible="{Binding HasResults}">
            <Grid RowDefinitions="Auto,*">
                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <Button DockPanel.Dock="Right" Content="{l:Tr Btn_OpenFolder}"
                            Command="{Binding OpenOutputFolderCommand}" />
                    <TextBlock Text="{l:Tr Results_Title}" FontWeight="Bold" VerticalAlignment="Center" />
                </DockPanel>
                <ListBox Grid.Row="1" ItemsSource="{Binding OutputFiles}" Height="150">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{Binding}" FontSize="12" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
        </Grid>
        </ScrollViewer>

        <!-- Закреплённая зона сообщений (Row 2): всегда видна; при длинном тексте — прокрутка.
             Вынесена из прокручиваемой середины, чтобы нижний бар «Обработать» оставался виден. -->
        <ScrollViewer Grid.Row="2" x:Name="MessageArea" MaxHeight="340" Margin="0,8,24,0"
                      HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel>
        <Border x:Name="WarningBlock"
                Background="#FDECEA" BorderBrush="#C42B1C" BorderThickness="2"
                CornerRadius="6" Padding="12" Margin="0,0,0,8"
                IsVisible="{Binding IsMessageVisible}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="⚠" FontSize="32" Foreground="#C42B1C"
                           VerticalAlignment="Top" Margin="0,0,12,0" />
                <StackPanel>
                    <!-- Обычное блок-сообщение (запрет пересечений, ошибки и т.п.) -->
                    <TextBlock Text="{Binding BlockMessage}" IsVisible="{Binding ShowPlainBlock}"
                               FontWeight="Bold" FontSize="14" Foreground="#C42B1C" TextWrapping="Wrap"
                               Margin="0,0,0,12" />

                    <!-- Цветная подсказка: включили «Без пересечений» при неразрешённом вопросе -->
                    <TextBlock IsVisible="{Binding ShowOverlapHint}" TextWrapping="Wrap"
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,12">
                        <Run Text="{l:Tr Hint_BlockPrefix}" Foreground="#0078D4" />
                        <Run Text="{l:Tr Hint_BlockName}" Foreground="#C42B1C" />
                        <Run Text="{l:Tr Hint_BlockSuffix}" Foreground="#0078D4" />
                    </TextBlock>

                    <!-- Предупреждение о пересечении -->
                    <StackPanel IsVisible="{Binding HasOverlapWarning}">
                        <TextBlock Text="{l:Tr Overlap_Title}"
                                   FontWeight="Bold" FontSize="14" Foreground="#C42B1C"
                                   TextWrapping="Wrap" Margin="0,0,0,6" />
                        <!-- Таблица с общими ширинами столбцов: строки выравниваются по столбцам. -->
                        <ItemsControl ItemsSource="{Binding Overlaps}" Grid.IsSharedSizeScope="True">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:OverlapInfo">
                                    <Grid Margin="0,2" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ovNew" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ovInt" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ovEx" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="ovSrc" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="12" FontWeight="Bold">
                                            <Run Text="{l:Tr Overlap_RangeWord}" />
                                            <Run Text="{Binding NewPages}" />
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" FontSize="12" FontWeight="Bold" Foreground="#C42B1C"
                                                   Text="{l:Tr Overlap_IntersectsWord}" />
                                        <TextBlock Grid.Column="2" FontSize="12" FontWeight="Bold">
                                            <Run Text="{l:Tr Overlap_RangeWord}" />
                                            <Run Text="{Binding ExistingPages}" />
                                        </TextBlock>
                                        <TextBlock Grid.Column="3" FontSize="12" Foreground="#888"
                                                   Text="{Binding Source}" />
                                        <TextBlock Grid.Column="4" FontSize="12" FontWeight="Bold" Foreground="#C42B1C"
                                                   TextWrapping="Wrap" Text="{Binding Dup}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" FontSize="12">
                            <Run Text="{l:Tr Overlap_Duplicated}" FontWeight="Bold" />
                            <Run Text="{Binding DuplicatedPagesText}" FontWeight="Bold" Foreground="#C42B1C" />
                        </TextBlock>
                        <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" FontSize="14"
                                   IsVisible="{Binding HasPendingDecision}">
                            <Run Text="{l:Tr Overlap_WithoutAdds}" FontWeight="Bold" Foreground="#1B7F34" />
                            <Run Text="{Binding PendingResolveText}" FontWeight="Bold" Foreground="#1B7F34" />
                        </TextBlock>
                        <!-- Кнопки решения видны только пока решение не принято (после «Добавить ещё раз» — скрыты) -->
                        <WrapPanel Margin="0,12,0,0" IsVisible="{Binding HasPendingDecision}">
                            <Button Content="{l:Tr Btn_AddAgain}" Margin="0,0,8,4"
                                    Command="{Binding KeepOverlapRangeCommand}"
                                    ToolTip.Tip="{l:Tr Tip_AddAgain}" />
                            <Button Content="{l:Tr Btn_AddWithout}" Margin="0,0,8,4"
                                    Background="#1B7F34" Foreground="White" FontWeight="Bold"
                                    Command="{Binding KeepWithoutOverlapCommand}"
                                    ToolTip.Tip="{l:Tr Tip_AddWithout}" />
                            <Button Content="{l:Tr Btn_Remove}" Margin="0,0,0,4" Foreground="#C42B1C"
                                    Command="{Binding RemoveOverlapRangeCommand}"
                                    ToolTip.Tip="{l:Tr Tip_Remove}" />
                        </WrapPanel>
                    </StackPanel>

                    <!-- Разрешение конфликта (режим «Без пересечений» при уже имеющихся пересечениях) -->
                    <StackPanel IsVisible="{Binding HasConflictPrompt}" Margin="0,12,0,0">
                        <TextBlock Text="{l:Tr Conflict_Title}"
                                   FontWeight="Bold" FontSize="14" Foreground="#1B7F34"
                                   TextWrapping="Wrap" Margin="0,0,0,6" />
                        <TextBlock Text="{l:Tr Conflict_Proposed}"
                                   FontSize="12" Foreground="#555" Margin="0,0,0,4" />
                        <ItemsControl ItemsSource="{Binding ResolvedRanges}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock Text="{Binding}" FontWeight="SemiBold" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="{l:Tr Btn_Confirm}" Margin="0,0,8,4" Command="{Binding ConfirmResolveCommand}"
                                    Background="#1B7F34" Foreground="White" FontWeight="Bold"
                                    ToolTip.Tip="{l:Tr Tip_Confirm}" />
                            <Button Content="{l:Tr Btn_RemoveOverlapping}" Margin="0,0,8,4" Foreground="#C42B1C"
                                    Command="{Binding RemoveOverlappingRangesCommand}"
                                    ToolTip.Tip="{l:Tr Tip_RemoveOverlapping}" />
                            <!-- Появляется с небольшой задержкой, чтобы не нажать случайно -->
                            <Button Content="{l:Tr Btn_KeepOverlaps}" Margin="0,0,0,4"
                                    IsVisible="{Binding ShowKeepOverlapsButton}"
                                    Command="{Binding KeepExistingOverlapsCommand}"
                                    ToolTip.Tip="{l:Tr Tip_KeepOverlaps}" />
                        </WrapPanel>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Запрос на объединение с существующей группой -->
        <Border Background="#EAF3FE" BorderBrush="#0078D4" BorderThickness="2"
                CornerRadius="6" Padding="12" Margin="0,0,0,8"
                IsVisible="{Binding HasMergePrompt}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="❓" FontSize="28" Foreground="#0078D4"
                           VerticalAlignment="Top" Margin="0,0,12,0" />
                <StackPanel>
                    <TextBlock Text="{Binding MergePromptText}" TextWrapping="Wrap"
                               FontWeight="SemiBold" Foreground="#0A4A82" FontSize="13" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="{l:Tr Btn_AddToGroup}" Command="{Binding ConfirmMergeCommand}"
                                Background="#0078D4" Foreground="White" FontWeight="Bold" />
                        <Button Content="{l:Tr Btn_OtherName}" Margin="8,0,0,0"
                                Command="{Binding CancelMergeCommand}" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
        </StackPanel>
        </ScrollViewer>

        <!-- Закреплённый низ: «Сохранить в» + кнопки «Обработать»/«Без пересечений» всегда видны (вне прокрутки) -->
        <Border Grid.Row="3" x:Name="BottomBar" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                Padding="0,8,0,0" Margin="0,4,24,0">
            <StackPanel>
                <!-- Куда сохранять (на всю ширину) -->
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                        Padding="10" Margin="0,0,0,8">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0" Text="{l:Tr Save_Title}" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox Grid.Column="1" Text="{Binding OutputDirectory}" IsReadOnly="True"
                                 VerticalAlignment="Center" PlaceholderText="{l:Tr Save_Placeholder}" />
                        <Button Grid.Column="2" Content="{l:Tr Btn_Browse}" Margin="8,0,0,0"
                                Command="{Binding BrowseOutputDirectoryCommand}" ToolTip.Tip="{l:Tr Tip_BrowseOutput}" />
                    </Grid>
                </Border>

                <!-- Баннер обновления (показывается после «Обнаружено обновление») -->
                <Border Background="#E7F3E8" BorderBrush="#3A8A3F" BorderThickness="1" CornerRadius="6"
                        Padding="10,8" Margin="0,0,0,8" IsVisible="{Binding IsUpdateReady}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="{l:Tr Btn_Postpone}" Margin="0,0,8,0"
                                    Command="{Binding PostponeUpdateCommand}"
                                    ToolTip.Tip="{l:Tr Tip_Postpone}" />
                            <Button Content="{l:Tr Btn_UpdateRestart}"
                                    Command="{Binding ApplyUpdateCommand}"
                                    Background="#3A8A3F" Foreground="White" FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Text="{Binding UpdateText}" VerticalAlignment="Center"
                                   Foreground="#1E5E22" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </DockPanel>
                </Border>

                <!-- Сообщения выводятся в области уведомлений (баннер выше), а не рядом с кнопками. -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{l:Tr Btn_Process}" Command="{Binding ProcessCommand}"
                            IsEnabled="{Binding !IsProcessing}"
                            Padding="20,8" FontSize="15" FontWeight="Bold"
                            Background="#0078D4" Foreground="White" />
                    <!-- Тумблер «Без пересечений»: запрещает добавлять пересекающиеся диапазоны/группы -->
                    <ToggleButton Content="{l:Tr Btn_BlockOverlaps}" Margin="10,0,0,0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding BlockOverlaps}"
                                  IsEnabled="{Binding IsRangeInputEnabled}"
                                  ToolTip.Tip="{l:Tr Tip_BlockOverlaps}" />
                    <ProgressBar Width="120" Margin="12,0" IsIndeterminate="{Binding IsProcessing}"
                                 IsVisible="{Binding IsProcessing}" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>
        </Grid>
      </Grid>

      <!-- Увеличенный просмотр поверх всего; клик вне панели сворачивает -->
      <Border IsVisible="{Binding IsZoomOpen}" Background="#D0000000"
              PointerPressed="ZoomOverlay_PointerPressed">
          <Grid>
              <!-- Viewbox масштабирует уже ПОВЁРНУТОЕ изображение под область просмотра, поэтому
                   при 90°/270° страница не обрезается, а ужимается и остаётся по центру.
                   LayoutTransformControl делает поворот частью компоновки (учитываются новые
                   габариты); Image со Stretch=None отдаёт натуральный размер — масштаб задаёт Viewbox. -->
              <Viewbox Stretch="Uniform" Margin="40,74,40,40"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                  <LayoutTransformControl LayoutTransform="{Binding ZoomRotation, Converter={StaticResource AngleToTransform}}">
                      <Image Source="{Binding ZoomImage}" Stretch="None" />
                  </LayoutTransformControl>
              </Viewbox>
              <!-- Пиктограммы поворота сверху по центру (только в увеличенном виде) -->
              <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,16,0,0"
                      Background="#FFF3F3F3" CornerRadius="8" Padding="8,5"
                      BorderBrush="#33000000" BorderThickness="1" BoxShadow="0 2 8 0 #66000000">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                      <Button Content="↶" FontSize="20" FontWeight="Bold" Width="46" Foreground="#1A1A1A"
                              Command="{Binding RotateZoomLeftCommand}"
                              ToolTip.Tip="{l:Tr Tip_RotateLeft}" />
                      <Button Content="↷" FontSize="20" FontWeight="Bold" Width="46" Foreground="#1A1A1A"
                              Command="{Binding RotateZoomRightCommand}"
                              ToolTip.Tip="{l:Tr Tip_RotateRight}" />
                  </StackPanel>
              </Border>
          </Grid>
      </Border>
    </Grid>
</Window>
