<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PdfGrouping.Desktop.ViewModels"
        xmlns:conv="clr-namespace:PdfGrouping.Desktop.Converters"
        xmlns:models="clr-namespace:PdfGrouping.Core.Models;assembly=PdfGrouping.Core"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="PdfGrouping.Desktop.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainViewModel"
        Title="PDF Grouping — Разделение и группировка PDF"
        Width="1000" Height="800" MinWidth="780" MinHeight="660"
        WindowStartupLocation="CenterScreen"
        DragDrop.AllowDrop="True">

    <Window.Resources>
        <conv:BoolToBrushConverter x:Key="BoolToBrush" />
    </Window.Resources>

    <Grid Margin="12">
      <Grid ColumnDefinitions="Auto,*">

        <!-- Панель предпросмотра (слева, включается кнопкой «👁 Предпросмотр») -->
        <Border Grid.Column="0" Width="300" Margin="0,0,12,0"
                BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10"
                IsVisible="{Binding IsPreviewEnabled}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Предпросмотр страниц"
                           FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock DockPanel.Dock="Top"
                           Text="Выберите диапазон в списке, чтобы увидеть его начальную и конечную страницы."
                           TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"
                           Foreground="#777" FontSize="12" IsVisible="{Binding !HasPreview}" />
                <ScrollViewer IsVisible="{Binding HasPreview}">
                    <StackPanel>
                        <!-- Начальная страница -->
                        <TextBlock Text="{Binding SelectedRange.StartPage, StringFormat='Начальная страница: {0}'}"
                                   FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,3" />
                        <Border Background="#F7F7F7" BorderBrush="#E0E0E0" BorderThickness="1" Padding="4"
                                HorizontalAlignment="Center">
                            <Image Source="{Binding StartThumb}" Stretch="Uniform" MaxHeight="230" />
                        </Border>
                        <Button Content="🔍 Увеличить" Margin="0,4,0,0" HorizontalAlignment="Center"
                                Command="{Binding ZoomStartCommand}"
                                ToolTip.Tip="Открыть начальную страницу почти на весь экран" />

                        <!-- Разделитель с информацией о диапазоне -->
                        <Grid ColumnDefinitions="*,Auto,*" Margin="0,12">
                            <Border Grid.Column="0" Height="1" Background="#D8D8D8" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Margin="8,0" FontSize="12" Foreground="#666"
                                       VerticalAlignment="Center" Text="{Binding PreviewRangeText}" />
                            <Border Grid.Column="2" Height="1" Background="#D8D8D8" VerticalAlignment="Center" />
                        </Grid>

                        <!-- Конечная страница -->
                        <TextBlock Text="{Binding SelectedRange.EndPage, StringFormat='Конечная страница: {0}'}"
                                   FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,3" />
                        <Border Background="#F7F7F7" BorderBrush="#E0E0E0" BorderThickness="1" Padding="4"
                                HorizontalAlignment="Center">
                            <Image Source="{Binding EndThumb}" Stretch="Uniform" MaxHeight="230" />
                        </Border>
                        <Button Content="🔍 Увеличить" Margin="0,4,0,0" HorizontalAlignment="Center"
                                Command="{Binding ZoomEndCommand}"
                                ToolTip.Tip="Открыть конечную страницу почти на весь экран" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">

        <!-- Верхняя панель: справа кнопка «О программе» -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="ℹ О программе" Padding="8,4"
                    ToolTip.Tip="Сведения о программе и проверка обновлений">
                <Button.Flyout>
                    <Flyout Placement="BottomEdgeAlignedRight">
                        <StackPanel Width="300">
                            <TextBlock Text="PDF Grouping" FontWeight="Bold" FontSize="16" />
                            <TextBlock Text="slice &amp; group PDF" FontStyle="Italic" Foreground="#555" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding AppVersion, StringFormat='Версия {0}'}"
                                       Foreground="#555" Margin="0,0,0,4" />
                            <TextBlock Text="Автор: Inbasko" Margin="0,0,0,2" />
                            <TextBlock Text="github.com/OlBaskov-rec/inb-pdfGrouping"
                                       Foreground="#777" FontSize="12" />
                            <Border Height="1" Background="#E0E0E0" Margin="0,8" />
                            <Button Content="Проверить обновление"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Command="{Binding CheckUpdatesManualCommand}" />
                            <TextBlock Text="{Binding UpdateCheckStatus}" TextWrapping="Wrap"
                                       FontSize="12" Foreground="#555" Margin="0,6,0,0" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <TextBlock />
        </DockPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
        <!-- Правый отступ — зазор под вертикальную полосу прокрутки, чтобы она не наезжала -->
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,0,24,0">

        <!-- Row 0: исходный файл -->
        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                Padding="10" Margin="0,0,0,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Исходный PDF-файл"
                           FontWeight="Bold" Margin="0,0,0,6" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button Content="Обзор…" Command="{Binding BrowseSourceFileCommand}"
                            ToolTip.Tip="Выбрать PDF-файл" />
                    <Button Content="✕" Margin="6,0,0,0" Foreground="#C42B1C"
                            Command="{Binding ClearAllCommand}" ToolTip.Tip="Сбросить всё" />
                </StackPanel>
                <TextBox Text="{Binding SourceFilePath}" IsReadOnly="True"
                         PlaceholderText="Перетащите PDF сюда или нажмите «Обзор…»"
                         VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Row 1: всего страниц (под блоком пути к файлу) -->
        <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="4" Padding="8" Margin="0,0,0,8">
            <TextBlock>
                <Run Text="Всего страниц в источнике:" Foreground="Gray" />
                <Run Text="{Binding TotalPages}" FontWeight="Bold" />
            </TextBlock>
        </Border>

        <!-- Row 2: диапазоны | метка | группы (высота по списку диапазонов; колонки тянутся вместе) -->
        <!-- MinWidth колонок не даёт секции «Диапазоны» сжаться под два поля номеров (наезжание при предпросмотре). -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="350" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="250" />
            </Grid.ColumnDefinitions>

            <!-- Диапазоны -->
            <Border Grid.Column="0" MinWidth="240" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Text="Диапазоны страниц" FontWeight="Bold" Margin="0,0,0,6" />

                    <StackPanel Grid.Row="1" Margin="0,0,0,0">
                        <TextBlock Margin="0,0,0,4" Foreground="#444">
                            <Run Text="Страницы (из " />
                            <Run Text="{Binding TotalPages}" FontWeight="Bold" />
                            <Run Text="):" />
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <NumericUpDown Value="{Binding RangeStart}" Minimum="1" Maximum="{Binding MaxPage}"
                                           Increment="1" FormatString="0" Width="140" FontSize="16"
                                           ToolTip.Tip="Начальная страница" />
                            <TextBlock Text="–" VerticalAlignment="Center" Margin="8,0" FontSize="16" />
                            <NumericUpDown Value="{Binding RangeEnd}" Minimum="1" Maximum="{Binding MaxPage}"
                                           Increment="1" FormatString="0" Width="140" FontSize="16"
                                           ToolTip.Tip="Конечная страница" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,6">
                        <Button Margin="0,12,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding AddRangeCommand}" IsEnabled="{Binding !IsProcessing}">
                            <TextBlock Text="+ Добавить диапазон" TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                        <Button Margin="0,12,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding AddRangePaginatedCommand}" IsEnabled="{Binding !IsProcessing}"
                                ToolTip.Tip="Раскидать выбранные страницы на отдельные диапазоны по 1 странице">
                            <TextBlock Text="+ Добавить диапазон постранично" TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                        <DockPanel LastChildFill="False" Margin="0,18,0,0">
                            <Button DockPanel.Dock="Left" Content="Очистить"
                                    Command="{Binding ClearRangesCommand}" />
                            <ToggleButton DockPanel.Dock="Right" Content="👁 Предпросмотр"
                                          IsChecked="{Binding IsPreviewEnabled}"
                                          ToolTip.Tip="Показать миниатюры начальной и конечной страниц выбранного диапазона" />
                        </DockPanel>
                    </StackPanel>

                    <ListBox Grid.Row="3" ItemsSource="{Binding Ranges}"
                             Height="{Binding RangesListHeight}"
                             Padding="2,2,18,2"
                             SelectionMode="Single"
                             SelectedItem="{Binding SelectedRange}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:PageRange">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="Стр." FontSize="11" Foreground="Gray" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding StartPage}" FontWeight="Bold" Margin="3,0,0,0" />
                                        <TextBlock Text="–" Margin="3,0" />
                                        <TextBlock Text="{Binding EndPage}" FontWeight="Bold" />
                                        <TextBlock Text="{Binding PageCount, StringFormat=' ({0} стр.)'}"
                                                   FontSize="11" Foreground="Gray" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="✕" Padding="6,2" Foreground="#C42B1C"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{ReflectionBinding $parent[ListBox].DataContext.RemoveRangeCommand}"
                                            CommandParameter="{Binding}" ToolTip.Tip="Убрать этот диапазон" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Метка группы -->
            <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                    Padding="10" Margin="8,0" Width="210">
                <DockPanel>
                    <!-- Верх: метка, поле ввода, быстрый выбор, заголовок списка -->
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Метка группы" FontWeight="Bold" Margin="0,0,0,2" />
                        <TextBlock Text="(любые 15 симв.)" FontSize="12" Foreground="#777" Margin="0,0,0,2" />
                        <TextBox Text="{Binding GroupLabelText}" MaxLength="15"
                                 PlaceholderText="напр. А, Б, 1, Часть1" />
                        <!-- Быстрый выбор метки: 5 кнопок в один ряд -->
                        <WrapPanel Margin="0,6,0,0">
                            <Button Content="A" Width="30" Margin="0,0,4,0" Command="{Binding PickLabelCommand}" CommandParameter="A" />
                            <Button Content="B" Width="30" Margin="0,0,4,0" Command="{Binding PickLabelCommand}" CommandParameter="B" />
                            <Button Content="C" Width="30" Margin="0,0,4,0" Command="{Binding PickLabelCommand}" CommandParameter="C" />
                            <Button Content="D" Width="30" Margin="0,0,4,0" Command="{Binding PickLabelCommand}" CommandParameter="D" />
                            <Button Content="E" Width="30" Command="{Binding PickLabelCommand}" CommandParameter="E" />
                        </WrapPanel>
                        <TextBlock Text="Текущие диапазоны:" FontWeight="SemiBold" FontSize="12" Margin="0,12,0,2" />
                    </StackPanel>

                    <!-- Низ: кнопки создания группы (отступы в 1.5× — до, между и после) -->
                    <StackPanel DockPanel.Dock="Bottom">
                        <Button Margin="0,12,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding AddGroupCommand}" IsEnabled="{Binding !IsProcessing}">
                            <TextBlock Text="Создать группу для вывода ►"
                                       TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                        <Button Margin="0,12,0,12" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                Command="{Binding AddGroupPerRangeCommand}" IsEnabled="{Binding !IsProcessing}"
                                ToolTip.Tip="Каждый текущий диапазон станет отдельной группой (отдельным файлом)">
                            <TextBlock Text="Создать группу для вывода по каждому диапазону ►"
                                       TextWrapping="Wrap" TextAlignment="Center" />
                        </Button>
                    </StackPanel>

                    <!-- Середина: список выбранных диапазонов занимает всё свободное место -->
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,4">
                        <TextBlock Text="{Binding RangesDisplayText}" TextWrapping="Wrap" Foreground="#555" />
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Группы -->
            <Border Grid.Column="2" MinWidth="240" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="Сформированные группы" FontWeight="Bold" Margin="0,0,0,6" />

                    <ListBox Grid.Row="1" ItemsSource="{Binding Groups}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:PdfGroup">
                                <Grid ColumnDefinitions="*,Auto">
                                    <WrapPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Label, StringFormat='[{0}]'}"
                                                   FontWeight="Bold" Foreground="#0078D4" />
                                        <TextBlock Text="{Binding TotalPages, StringFormat=' — {0} стр.'}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding RangesText, StringFormat=' (диапазоны: {0})'}"
                                                   FontSize="11" Foreground="#777" />
                                    </WrapPanel>
                                    <Button Grid.Column="1" Content="✕" Padding="6,2" Foreground="#C42B1C"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{ReflectionBinding $parent[ListBox].DataContext.RemoveGroupCommand}"
                                            CommandParameter="{Binding}" ToolTip.Tip="Удалить группу" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 3: область сообщений (предупреждение о пересечениях + запрос на объединение) -->
        <StackPanel Grid.Row="3">
        <Border x:Name="WarningBlock"
                Background="#FDECEA" BorderBrush="#C42B1C" BorderThickness="2"
                CornerRadius="6" Padding="12" Margin="0,0,0,8"
                IsVisible="{Binding IsMessageVisible}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="⚠" FontSize="32" Foreground="#C42B1C"
                           VerticalAlignment="Top" Margin="0,0,12,0" />
                <StackPanel>
                    <!-- Запрет пересечений -->
                    <TextBlock Text="{Binding BlockMessage}" IsVisible="{Binding HasBlockMessage}"
                               FontWeight="Bold" FontSize="14" Foreground="#C42B1C" TextWrapping="Wrap" />

                    <!-- Предупреждение о пересечении -->
                    <StackPanel IsVisible="{Binding HasOverlapWarning}">
                        <TextBlock Text="Внимание: пересечение с уже выбранными страницами"
                                   FontWeight="Bold" FontSize="14" Foreground="#C42B1C"
                                   TextWrapping="Wrap" Margin="0,0,0,6" />
                        <ItemsControl ItemsSource="{Binding Overlaps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:OverlapInfo">
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,2">
                                        <Run Text="Диапазон " FontWeight="Bold" />
                                        <Run Text="{Binding NewPages}" FontWeight="Bold" />
                                        <Run Text="  пересекает  " Foreground="#C42B1C" FontWeight="Bold" />
                                        <Run Text="Диапазон " FontWeight="Bold" />
                                        <Run Text="{Binding ExistingPages}" FontWeight="Bold" />
                                        <Run Text="  ·  " Foreground="#888" />
                                        <Run Text="{Binding Source}" Foreground="#888" />
                                        <Run Text="   (повторяются: " Foreground="#C42B1C" FontWeight="Bold" />
                                        <Run Text="{Binding Dup}" Foreground="#C42B1C" FontWeight="Bold" />
                                        <Run Text=")" Foreground="#C42B1C" FontWeight="Bold" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" FontSize="12">
                            <Run Text="Дублируются: " FontWeight="Bold" />
                            <Run Text="{Binding DuplicatedPagesText}" FontWeight="Bold" Foreground="#C42B1C" />
                        </TextBlock>
                        <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" FontSize="14"
                                   IsVisible="{Binding HasPendingDecision}">
                            <Run Text="Без пересечения добавится: " FontWeight="Bold" Foreground="#1B7F34" />
                            <Run Text="{Binding PendingResolveText}" FontWeight="Bold" Foreground="#1B7F34" />
                        </TextBlock>
                        <!-- Кнопки решения видны только пока решение не принято (после «Добавить ещё раз» — скрыты) -->
                        <WrapPanel Margin="0,12,0,0" IsVisible="{Binding HasPendingDecision}">
                            <Button Content="Добавить ещё раз" Margin="0,0,8,4"
                                    Command="{Binding KeepOverlapRangeCommand}"
                                    ToolTip.Tip="Оставить диапазон как есть — страницы продублируются" />
                            <Button Content="Добавить без пересечения" Margin="0,0,8,4"
                                    Background="#1B7F34" Foreground="White" FontWeight="Bold"
                                    Command="{Binding KeepWithoutOverlapCommand}"
                                    ToolTip.Tip="Добавить только свободные страницы (диапазон обрезается)" />
                            <Button Content="Убрать" Margin="0,0,0,4" Foreground="#C42B1C"
                                    Command="{Binding RemoveOverlapRangeCommand}"
                                    ToolTip.Tip="Не добавлять этот диапазон" />
                        </WrapPanel>
                    </StackPanel>

                    <!-- Разрешение конфликта (режим «Без пересечений» при уже имеющихся пересечениях) -->
                    <StackPanel IsVisible="{Binding HasConflictPrompt}" Margin="0,12,0,0">
                        <TextBlock Text="Решение конфликта по пересечению страниц диапазонов"
                                   FontWeight="Bold" FontSize="14" Foreground="#1B7F34"
                                   TextWrapping="Wrap" Margin="0,0,0,6" />
                        <TextBlock Text="Предлагаемые непересекающиеся диапазоны:"
                                   FontSize="12" Foreground="#555" Margin="0,0,0,4" />
                        <ItemsControl ItemsSource="{Binding ResolvedRanges}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock Text="{Binding}" FontWeight="SemiBold" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Подтвердить" Command="{Binding ConfirmResolveCommand}"
                                    Background="#1B7F34" Foreground="White" FontWeight="Bold"
                                    ToolTip.Tip="Применить непересекающиеся диапазоны (обрезка/разбиение)" />
                            <Button Content="Убрать пересекающиеся" Margin="8,0,0,0" Foreground="#C42B1C"
                                    Command="{Binding RemoveOverlappingRangesCommand}"
                                    ToolTip.Tip="Оставить только первые занявшие страницы диапазоны" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Запрос на объединение с существующей группой -->
        <Border Background="#EAF3FE" BorderBrush="#0078D4" BorderThickness="2"
                CornerRadius="6" Padding="12" Margin="0,0,0,8"
                IsVisible="{Binding HasMergePrompt}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="❓" FontSize="28" Foreground="#0078D4"
                           VerticalAlignment="Top" Margin="0,0,12,0" />
                <StackPanel>
                    <TextBlock Text="{Binding MergePromptText}" TextWrapping="Wrap"
                               FontWeight="SemiBold" Foreground="#0A4A82" FontSize="13" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Добавить в группу" Command="{Binding ConfirmMergeCommand}"
                                Background="#0078D4" Foreground="White" FontWeight="Bold" />
                        <Button Content="Другое название" Margin="8,0,0,0"
                                Command="{Binding CancelMergeCommand}" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
        </StackPanel>

        <!-- Row 4: куда сохранять (на всю ширину) -->
        <Border Grid.Row="4" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                Padding="10" Margin="0,0,0,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="Сохранить результаты в:" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Grid.Column="1" Text="{Binding OutputDirectory}" IsReadOnly="True"
                         VerticalAlignment="Center" PlaceholderText="папка для результатов" />
                <Button Grid.Column="2" Content="Обзор…" Margin="8,0,0,0"
                        Command="{Binding BrowseOutputDirectoryCommand}" ToolTip.Tip="Выбрать папку" />
            </Grid>
        </Border>

        <!-- Row 6: результаты (созданные файлы) -->
        <Border Grid.Row="6" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                Padding="10" IsVisible="{Binding HasResults}">
            <Grid RowDefinitions="Auto,*">
                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <Button DockPanel.Dock="Right" Content="📂 Открыть папку"
                            Command="{Binding OpenOutputFolderCommand}" />
                    <TextBlock Text="Созданные файлы" FontWeight="Bold" VerticalAlignment="Center" />
                </DockPanel>
                <ListBox Grid.Row="1" ItemsSource="{Binding OutputFiles}" Height="150">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{Binding}" FontSize="12" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
        </Grid>
        </ScrollViewer>

        <!-- Закреплённый низ: кнопки «Обработать»/«Без пересечений» всегда видны (вне прокрутки) -->
        <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                Padding="0,8,0,0" Margin="0,4,24,0">
            <StackPanel>
                <!-- Баннер обновления (виден только когда обновление скачано) -->
                <Border Background="#E7F3E8" BorderBrush="#3A8A3F" BorderThickness="1" CornerRadius="6"
                        Padding="10,8" Margin="0,0,0,8" IsVisible="{Binding IsUpdateReady}">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="⟳ Обновить и перезапустить"
                                Command="{Binding ApplyUpdateCommand}"
                                Background="#3A8A3F" Foreground="White" FontWeight="Bold" />
                        <TextBlock Text="{Binding UpdateText}" VerticalAlignment="Center"
                                   Foreground="#1E5E22" FontWeight="SemiBold" />
                    </DockPanel>
                </Border>

                <!-- Сообщения выводятся в области уведомлений (баннер выше), а не рядом с кнопками. -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="▶ Обработать" Command="{Binding ProcessCommand}"
                            IsEnabled="{Binding !IsProcessing}"
                            Padding="20,8" FontSize="15" FontWeight="Bold"
                            Background="#0078D4" Foreground="White" />
                    <!-- Тумблер «Без пересечений»: запрещает добавлять пересекающиеся диапазоны/группы -->
                    <ToggleButton Content="🚫 Без пересечений" Margin="10,0,0,0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding BlockOverlaps}"
                                  ToolTip.Tip="Во включённом состоянии нельзя выбрать пересекающиеся страницы (диапазоны и группы)" />
                    <ProgressBar Width="120" Margin="12,0" IsIndeterminate="{Binding IsProcessing}"
                                 IsVisible="{Binding IsProcessing}" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>
        </Grid>
      </Grid>

      <!-- Увеличенный просмотр поверх всего; клик в любом месте сворачивает -->
      <Border IsVisible="{Binding IsZoomOpen}" Background="#D0000000"
              PointerPressed="ZoomOverlay_PointerPressed">
          <Image Source="{Binding ZoomImage}" Stretch="Uniform" Margin="40" />
      </Border>
    </Grid>
</Window>
