<Window x:Class="PdfGrouping.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PdfGrouping.App"
        xmlns:vm="clr-namespace:PdfGrouping.App.ViewModels"
        mc:Ignorable="d"
        Title="PDF Grouping — Разделение и группировка PDF" 
        Height="700" Width="1000"
        MinHeight="550" MinWidth="800"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Source file selection -->
        <GroupBox Grid.Row="0" Header="Исходный PDF-файл" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" 
                         Text="{Binding SourceFilePath, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         IsReadOnly="True"
                         Background="#F5F5F5"
                         ToolTip="{Binding SourceFilePath}"
                         AllowDrop="True"
                         Drop="SourceFileTextBox_Drop"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button Content="..." Width="32" Height="26"
                            Command="{Binding BrowseSourceFileCommand}"
                            ToolTip="Обзор..." VerticalAlignment="Center"/>
                    <Button Content="✕" Width="32" Height="26" Margin="4,0,0,0"
                            Command="{Binding ClearAllCommand}"
                            ToolTip="Сбросить всё" VerticalAlignment="Center"
                            Foreground="Red"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Row 1: Controls area (ranges + groups) -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Add ranges -->
            <GroupBox Grid.Column="0" Header="Диапазоны страниц">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Range inputs -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Страницы:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Text="{Binding RangeStartText, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="55" Height="24" VerticalAlignment="Center"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"
                                 ToolTip="Начальная страница"/>
                        <TextBlock Text="–" VerticalAlignment="Center" Margin="3,0"/>
                        <TextBox Text="{Binding RangeEndText, UpdateSourceTrigger=PropertyChanged}" 
                                 Width="55" Height="24" VerticalAlignment="Center"
                                 PreviewTextInput="NumericOnly_PreviewTextInput"
                                 ToolTip="Конечная страница"/>
                        <TextBlock VerticalAlignment="Center" Margin="4,0">
                            <Run Text="из"/><Run Text=" "/><Run Text="{Binding TotalPages}" FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Add range button -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="+ Добавить диапазон" 
                                Command="{Binding AddRangeCommand}"
                                Padding="10,4" Height="28"
                                IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBoolConverter}}"/>
                        <Button Content="Очистить" Margin="6,0,0,0"
                                Command="{Binding ClearRangesCommand}"
                                Padding="10,4" Height="28"/>
                    </StackPanel>

                    <!-- Ranges list -->
                    <ListBox Grid.Row="2" 
                             ItemsSource="{Binding Ranges}"
                             SelectionMode="Extended"
                             MinHeight="80">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Стр." FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding StartPage}" FontWeight="Bold" Margin="2,0,0,0"/>
                                    <TextBlock Text="–" Margin="2,0"/>
                                    <TextBlock Text="{Binding EndPage}" FontWeight="Bold"/>
                                    <TextBlock Text=" (" FontSize="11" Foreground="Gray"/>
                                    <TextBlock Text="{Binding PageCount}" FontSize="11" Foreground="Gray"/>
                                    <TextBlock Text=" стр.)" FontSize="11" Foreground="Gray"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </GroupBox>

            <!-- MIDDLE: Label input + Add group -->
            <GroupBox Grid.Column="1" Header="Метка группы" Margin="8,0" Width="160">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Margin="0,8,0,4">
                        <Run Text="Текущие диапазоны:" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock Grid.Row="1" 
                               Text="{Binding RangesDisplayText}" 
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="#555"/>

                    <StackPanel Grid.Row="2" VerticalAlignment="Center">
                        <TextBlock Text="Метка (буква/номер):" Margin="0,12,0,4" FontSize="12"/>
                        <TextBox Text="{Binding GroupLabelText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28" Width="130"
                                 ToolTip="Например: А, Б, 1, 2, Часть1"/>
                        <Button Content="Создать группу ►" Margin="0,10,0,0"
                                Padding="10,6"
                                Command="{Binding AddGroupCommand}"
                                IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBoolConverter}}"
                                Height="34"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- RIGHT PANEL: Groups -->
            <GroupBox Grid.Column="2" Header="Сформированные группы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0" 
                             ItemsSource="{Binding Groups}"
                             MinHeight="80"
                             Name="GroupsListBox">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="[" FontWeight="Bold" Foreground="#0078D4"/>
                                        <TextBlock Text="{Binding Label}" FontWeight="Bold" Foreground="#0078D4"/>
                                        <TextBlock Text="]" FontWeight="Bold" Foreground="#0078D4"/>
                                        <TextBlock Text=" — " Foreground="Gray"/>
                                        <TextBlock Text="{Binding TotalPages}" FontWeight="Bold"/>
                                        <TextBlock Text=" стр." Foreground="Gray"/>
                                        <TextBlock Text=" (диапазоны: " Foreground="Gray" FontSize="11"/>
                                        <TextBlock FontSize="11" Foreground="#777">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0}">
                                                    <Binding Path="Ranges" Converter="{StaticResource RangesToStringConverter}"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text=")" Foreground="Gray" FontSize="11"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="✕" Width="24" Height="24"
                                            Command="{Binding DataContext.RemoveGroupCommand, 
                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Foreground="Red" FontSize="10"
                                            Background="Transparent" BorderThickness="0"
                                            ToolTip="Удалить группу"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Output dir -->
                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Сохранить в:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Grid.Column="1" 
                                 Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" Height="24"
                                 IsReadOnly="True" Background="#F5F5F5"/>
                        <Button Grid.Column="2" Content="…" Width="28" Height="24" Margin="4,0,0,0"
                                Command="{Binding BrowseOutputDirectoryCommand}"/>
                    </Grid>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Row 2: Status info -->
        <Border Grid.Row="2" Background="#F0F0F0" CornerRadius="4" Padding="8" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="{Binding SourceFilePath}" 
                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                           FontSize="11" Foreground="#666"
                           Visibility="{Binding SourceFilePath, Converter={StaticResource StringToVisibilityConverter}}"/>
                <TextBlock>
                    <Run Text="Всего страниц:" Foreground="Gray"/>
                    <Run Text="{Binding TotalPages}" FontWeight="Bold"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Row 3: Bottom bar (Process + Status) -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="▶ Обработать" 
                        Command="{Binding ProcessCommand}"
                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBoolConverter}}"
                        Padding="20,8" Height="36"
                        Background="#0078D4" Foreground="White"
                        FontSize="15" FontWeight="Bold"
                        BorderThickness="0"/>
                <ProgressBar Width="100" Height="10" Margin="12,0"
                             IsIndeterminate="{Binding IsProcessing}"
                             Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>

            <TextBlock Grid.Column="1" 
                       Text="{Binding StatusText}"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       FontSize="13"
                       Foreground="{Binding IsProcessing, Converter={StaticResource ProcessingColorConverter}}"/>
        </Grid>
    </Grid>
</Window>